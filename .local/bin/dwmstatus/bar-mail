#!/bin/sh


n_mails=$(find "$XDG_DATA_HOME/mail" -path '*/INBOX/new/*' -type f 2>/dev/null | wc -l)

last_new=$(cat $XDG_CACHE_HOME/status/mail.new)

if [[ $n_mails -gt $last_new ]]
then
    notify-send "New Email" "$n_mails new messages"
    echo $n_mails > $XDG_CACHE_HOME/status/mail.new

else
    echo $n_mails > $XDG_CACHE_HOME/status/mail.new
fi

if [[ $n_mails -gt "0" ]]
then
    echo ""
fi

case $BLOCK_BUTTON in
	1) setsid -f "$TERMINAL" -e neomutt ;;
	2) pkill -RTMIN+3 dwmblocks && setsid -f mbsync -a ;;
	6) "$TERMINAL" -e "$EDITOR" "$0" ;;
esac

