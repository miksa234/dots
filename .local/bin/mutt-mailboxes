#!/bin/sh
# mutt-mailboxes: Auto-discover Maildir mailboxes and generate neomutt sidebar config.
#
# Scans $XDG_DATA_HOME/mail (default: ~/.local/share/mail) for Maildir
# directories and writes named-mailboxes entries to
# $XDG_CONFIG_HOME/mutt/mailboxes.
#
# Usage:
#   mutt-mailboxes           # regenerate mailboxes file
#
# The generated file is sourced by neomutt at startup and after each account
# switch so that all accounts always appear in the sidebar, regardless of
# which account is currently active.
#
# Run manually (or via the in-mutt macro) after adding/removing mail accounts
# with mbsync/isync.

MAIL_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/mail"
OUT_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/mutt/mailboxes"

# Write header
cat > "$OUT_FILE" << 'EOF'
# vim: filetype=neomuttrc
# Auto-generated by mutt-mailboxes — do not edit manually.
# Re-run:  mutt-mailboxes
# In mutt: press Ctrl+B to regenerate and reload.
EOF

[ -d "$MAIL_DIR" ] || exit 0

# Walk each account directory under MAIL_DIR.
# An account directory contains Maildir folders (subdirs with cur/ and new/).
for account_dir in "$MAIL_DIR"/*/; do
    [ -d "$account_dir" ] || continue
    account=$(basename "$account_dir")

    for maildir in "$account_dir"*/; do
        [ -d "${maildir}cur" ] && [ -d "${maildir}new" ] || continue
        folder=$(basename "$maildir")
        printf 'named-mailboxes "%s/%s" "%s"\n' \
            "$account" "$folder" "${maildir%/}" >> "$OUT_FILE"
    done
done
