[user]
	email = milutin@popovic.xyz
	name = Milutin Popovic
[init]
	defaultBranch = main
[credential "https://github.com"]
	helper =
	helper = !/etc/profiles/per-user/mika/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/etc/profiles/per-user/mika/bin/gh auth git-credential
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
    sshCommand = ssh -o IdentitiesOnly=yes -i ~/.ssh/mika.rsa
[credential]
	helper = store
